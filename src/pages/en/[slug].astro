---
import PageContent from "@/components/PageContent.astro";
import { getStaticPages, type PageKey } from "@/data/site";
import BaseLayout from "@/layouts/BaseLayout.astro";

export function getStaticPaths() {
  return getStaticPages("en").map(({ key, slug }) => ({
    params: { slug },
    props: { pageKey: key },
  }));
}

const { pageKey } = Astro.props as { pageKey: PageKey };
---

<BaseLayout locale="en" pageKey={pageKey}>
  <PageContent locale="en" pageKey={pageKey} />
</BaseLayout>
