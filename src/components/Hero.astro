---
import Icon from "@/components/Icon.astro";
import { brand, paths, processSteps, ui, type IconName, type Locale, type Page, type PageKey } from "@/data/site";

const { locale, page, pageKey } = Astro.props as { locale: Locale; page: Page; pageKey: PageKey };
const t = ui[locale];
const steps = processSteps[locale];
const summaryTitle =
  pageKey === "home"
    ? locale === "fr"
      ? "Votre informatique, prise en main."
      : "Your IT, taken in hand."
    : locale === "fr"
      ? "Comprendre vite. Régler proprement."
      : "Understand quickly. Fix cleanly.";
const summaryItems: [IconName, string][] =
  pageKey === "home"
    ? locale === "fr"
      ? [
          ["clock", "Gain de temps"],
          ["sparkles", "Performance"],
          ["shield", "Moins de stress"],
        ]
      : [
          ["clock", "Time saved"],
          ["sparkles", "Performance"],
          ["shield", "Less stress"],
        ]
    : locale === "fr"
      ? [
          ["phone", "Appel direct"],
          ["monitor", "Support à distance"],
          ["shield", "Session encadrée"],
        ]
      : [
          ["phone", "Direct call"],
          ["monitor", "Remote support"],
          ["shield", "Guided session"],
        ];
---

<section class="relative isolate overflow-hidden border-b border-border bg-background">
  <img
    src={page.image}
    alt=""
    aria-hidden="true"
    width="1600"
    height="1000"
    class="hero-photo"
    loading={pageKey === "home" ? "eager" : "lazy"}
  />
  <div class="hero-overlay"></div>
  <div class="absolute inset-x-0 top-0 h-1.5 bg-primary"></div>
  <div class="absolute inset-0 bg-[linear-gradient(115deg,rgba(20,85,155,.10),transparent_38%)]"></div>
  <div class="container relative grid min-h-[calc(100dvh-76px)] items-center gap-8 py-12 lg:grid-cols-[minmax(0,1fr)_360px] lg:py-14 xl:grid-cols-[minmax(0,1fr)_390px]">
    <div class="max-w-4xl reveal">
      <span class="badge">{page.eyebrow}</span>
      <h1 class="mt-5 font-heading text-4xl font-black leading-[1.04] sm:text-5xl lg:text-[3.5rem] xl:text-[3.75rem] 2xl:text-[4.25rem]">{page.h1}</h1>
      <p class="mt-5 max-w-2xl text-lg leading-8 text-muted-foreground sm:text-xl">{page.lead}</p>
      <div class="mt-6 flex flex-col gap-3 sm:flex-row">
        <a class="btn btn-primary w-full sm:w-auto" href={brand.phoneHref}>
          <Icon name="phone" class="size-5" />
          {t.call}: {brand.phone}
        </a>
        <a class="btn btn-secondary w-full sm:w-auto" href={`${paths.contact[locale]}#diagnostic`}>
          {t.diagnostic}
          <Icon name="arrow" class="size-5" />
        </a>
      </div>
      <div class="mt-9 grid border-y border-border sm:grid-cols-3">
        {steps.map(([title, text]) => (
          <div class="border-b border-border py-4 sm:border-b-0 sm:border-r sm:px-4 first:sm:pl-0 last:sm:border-r-0">
            <strong class="block text-sm font-black">{title}</strong>
            <span class="mt-1 block text-xs leading-5 text-muted-foreground">{text}</span>
          </div>
        ))}
      </div>
    </div>

    <aside class="hidden border border-border bg-card/90 p-5 shadow-premium backdrop-blur-xl reveal lg:block" aria-label={locale === "fr" ? "Résumé du service" : "Service summary"}>
      <span class="badge">{locale === "fr" ? "Réponse rapide" : "Fast response"}</span>
      <strong class="mt-4 block font-heading text-3xl font-black leading-tight">
        {summaryTitle}
      </strong>
      <div class="mt-6 grid gap-3 text-sm font-bold">
        {summaryItems.map(([icon, label]) => (
          <div class="flex items-center gap-3 border border-border bg-background/75 p-3">
            <Icon name={icon} class="size-5 text-primary" />
            <span>{label}</span>
          </div>
        ))}
      </div>
    </aside>
  </div>
</section>
