---
import Icon from "@/components/Icon.astro";
import { brand, paths, processSteps, ui, type Locale, type Page, type PageKey } from "@/data/site";

const { locale, page, pageKey } = Astro.props as { locale: Locale; page: Page; pageKey: PageKey };
const t = ui[locale];
const steps = processSteps[locale];
const isHome = pageKey === "home";
const carouselSlides =
  locale === "fr"
    ? [
        {
          kicker: "01",
          title: "Gain de temps",
          text: "Un diagnostic clair pour éviter les essais inutiles et choisir la bonne intervention.",
          image: "/images/remote-refresh.webp",
        },
        {
          kicker: "02",
          title: "Performance",
          text: "Des ordinateurs plus rapides, mieux entretenus et plus fiables au quotidien.",
          image: "/images/repair-refresh.webp",
        },
        {
          kicker: "03",
          title: "Moins de stress",
          text: "Un technicien local qui explique simplement et règle le problème proprement.",
          image: "/images/pme-refresh.webp",
        },
      ]
    : [
        {
          kicker: "01",
          title: "Time saved",
          text: "A clear diagnostic to avoid trial and error and choose the right intervention.",
          image: "/images/remote-refresh.webp",
        },
        {
          kicker: "02",
          title: "Performance",
          text: "Faster, better maintained and more reliable computers for everyday work.",
          image: "/images/repair-refresh.webp",
        },
        {
          kicker: "03",
          title: "Less stress",
          text: "A local technician who explains simply and fixes the issue cleanly.",
          image: "/images/pme-refresh.webp",
        },
      ];
---

<section class="relative isolate overflow-hidden border-b border-border bg-background">
  <img
    src={page.image}
    alt=""
    aria-hidden="true"
    width="1600"
    height="1000"
    class="hero-photo"
    loading={isHome ? "eager" : "lazy"}
  />
  <div class="hero-overlay"></div>
  <div class="absolute inset-x-0 top-0 h-1.5 bg-primary"></div>
  <div class="absolute inset-0 bg-[linear-gradient(115deg,rgba(20,85,155,.10),transparent_38%)]"></div>
  <div
    class:list={[
      "container relative grid min-h-[calc(100dvh-76px)] items-center gap-8",
      isHome
        ? "pt-5 pb-12 lg:grid-cols-[minmax(0,1fr)_430px] lg:py-14 xl:grid-cols-[minmax(0,1fr)_470px]"
        : "py-12 lg:grid-cols-1 lg:py-14",
    ]}
  >
    <div class:list={["max-w-4xl reveal", isHome && "order-2 lg:order-1"]}>
      <span class="badge">{page.eyebrow}</span>
      <h1 class="mt-5 font-heading text-4xl font-black leading-[1.04] sm:text-5xl lg:text-[3.5rem] xl:text-[3.75rem] 2xl:text-[4.25rem]">{page.h1}</h1>
      <p class="mt-5 max-w-2xl text-lg leading-8 text-muted-foreground sm:text-xl">{page.lead}</p>
      <div class="mt-6 flex flex-col gap-3 sm:flex-row">
        <a class="btn btn-primary w-full sm:w-auto" href={brand.phoneHref}>
          <Icon name="phone" class="size-5" />
          {t.call}: {brand.phone}
        </a>
        <a class="btn btn-secondary w-full sm:w-auto" href={`${paths.contact[locale]}#diagnostic`}>
          {t.diagnostic}
          <Icon name="arrow" class="size-5" />
        </a>
      </div>
      <div class:list={["mt-9 grid border-y border-border sm:grid-cols-3", isHome && "hidden lg:grid"]}>
        {steps.map(([title, text]) => (
          <div class="border-b border-border py-4 sm:border-b-0 sm:border-r sm:px-4 first:sm:pl-0 last:sm:border-r-0">
            <strong class="block text-sm font-black">{title}</strong>
            <span class="mt-1 block text-xs leading-5 text-muted-foreground">{text}</span>
          </div>
        ))}
      </div>
    </div>

    {isHome && (
      <aside
        class="home-carousel order-1 reveal lg:order-2"
        aria-label={locale === "fr" ? "Points forts Info Dorais" : "Info Dorais highlights"}
        data-home-carousel
        data-carousel-interval="4200"
      >
        {carouselSlides.map((slide, index) => (
          <article
            class:list={["home-slide", index === 0 && "is-active"]}
            aria-hidden={index === 0 ? "false" : "true"}
            data-home-slide={index}
          >
            <img
              src={slide.image}
              alt=""
              aria-hidden="true"
              width="760"
              height="620"
              loading={index === 0 ? "eager" : "lazy"}
              class="home-slide-media"
            />
            <div class="home-slide-overlay"></div>
            <div class="relative flex min-h-[360px] flex-col justify-end p-5 text-white sm:min-h-[430px] sm:p-7">
              <span class="text-xs font-black uppercase tracking-[0.16em] text-white/72">{slide.kicker}</span>
              <h2 class="mt-3 font-heading text-4xl font-black leading-none sm:text-5xl">{slide.title}</h2>
              <p class="mt-4 max-w-sm text-sm font-bold leading-6 text-white/82 sm:text-base">{slide.text}</p>
            </div>
          </article>
        ))}
        <div class="home-dot-group" aria-label={locale === "fr" ? "Navigation du diaporama" : "Slideshow navigation"}>
          {carouselSlides.map((slide, index) => (
            <button
              type="button"
              class:list={["home-dot", index === 0 && "is-active"]}
              aria-label={`${locale === "fr" ? "Afficher" : "Show"} ${slide.title}`}
              aria-current={index === 0 ? "true" : undefined}
              data-home-dot={index}
            ></button>
          ))}
        </div>
      </aside>
    )}
  </div>
</section>

<script is:inline>
  (() => {
    const initCarousel = () => {
      const carousel = document.querySelector("[data-home-carousel]");
      if (!carousel || carousel.dataset.carouselReady === "true") return;

      const slides = Array.from(carousel.querySelectorAll("[data-home-slide]"));
      const dots = Array.from(carousel.querySelectorAll("[data-home-dot]"));
      if (slides.length === 0) return;

      carousel.dataset.carouselReady = "true";
      let active = slides.findIndex((slide) => slide.classList.contains("is-active"));
      if (active < 0) active = 0;

      const showSlide = (nextIndex) => {
        active = (nextIndex + slides.length) % slides.length;
        slides.forEach((slide, index) => {
          const isActive = index === active;
          slide.classList.toggle("is-active", isActive);
          slide.setAttribute("aria-hidden", isActive ? "false" : "true");
        });
        dots.forEach((dot, index) => {
          const isActive = index === active;
          dot.classList.toggle("is-active", isActive);
          if (isActive) {
            dot.setAttribute("aria-current", "true");
          } else {
            dot.removeAttribute("aria-current");
          }
        });
      };

      let timer;
      const startTimer = () => {
        if (slides.length <= 1) return;
        window.clearInterval(timer);
        timer = window.setInterval(() => showSlide(active + 1), Number(carousel.dataset.carouselInterval || 4200));
      };

      dots.forEach((dot, index) => {
        dot.addEventListener("click", () => {
          showSlide(index);
          startTimer();
        });
      });

      document.addEventListener("visibilitychange", () => {
        if (document.hidden) {
          window.clearInterval(timer);
        } else {
          startTimer();
        }
      });

      showSlide(active);
      startTimer();
    };

    initCarousel();
    document.addEventListener("astro:page-load", initCarousel);
  })();
</script>
