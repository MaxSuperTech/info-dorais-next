---
import Icon from "@/components/Icon.astro";
import type { Locale, ServiceCard } from "@/data/site";

const { service, locale } = Astro.props as { service: ServiceCard; locale: Locale };
---

<article class="card card-hover group overflow-hidden">
  <div class="relative h-44 overflow-hidden border-b border-border bg-foreground">
    <img src={service.image} alt={service.title} loading="lazy" width="800" height="600" class="h-full w-full object-cover opacity-85 saturate-[.92] transition duration-300 group-hover:scale-[1.035] group-hover:opacity-100" />
    <div class="absolute inset-0 bg-gradient-to-tr from-foreground/88 via-foreground/30 to-primary/10"></div>
    <div class="visual-grid visual-scan absolute inset-0 opacity-55"></div>
    <div class="absolute left-4 top-4 flex size-12 items-center justify-center border border-background/20 bg-background text-primary shadow-line">
      <Icon name={service.icon} class="size-6" />
    </div>
    <div class="absolute bottom-4 left-4 right-4 border border-background/15 bg-foreground/85 px-3 py-2 text-xs font-black uppercase tracking-[0.08em] text-background backdrop-blur">
      {service.tags[0]}
    </div>
  </div>
  <div class="p-6">
    <Icon name={service.icon} class="mb-4 size-7 text-primary" />
    <h3 class="font-heading text-xl font-black">{service.title}</h3>
    <p class="mt-3 text-sm leading-6 text-muted-foreground">{service.text}</p>
    <div class="mt-5 flex flex-wrap gap-2 border-t border-border pt-4">
      {service.tags.map((tag) => <span class="bg-primary/10 px-2.5 py-1 text-xs font-bold text-primary">{tag}</span>)}
    </div>
    <a class="btn btn-secondary mt-5 w-full" href={service.href}>
      <span>{locale === "en" ? "Learn more" : "En savoir plus"}</span>
      <Icon name="arrow" class="size-4" />
    </a>
  </div>
</article>
